{
  "_comment": "ADLC pipeline allowlist — copied into each project's .claude/settings.json by /init. Reduces permission prompts during /proceed by pre-approving the routine read/write/git/gh/test/agent operations the pipeline fires. Destructive or production-impact operations remain on the ask list.",
  "permissions": {
    "defaultMode": "acceptEdits",
    "allow": [
      "Bash(git status:*)",
      "Bash(git diff:*)",
      "Bash(git log:*)",
      "Bash(git show:*)",
      "Bash(git branch:*)",
      "Bash(git add:*)",
      "Bash(git commit:*)",
      "Bash(git push:*)",
      "Bash(git pull:*)",
      "Bash(git fetch:*)",
      "Bash(git checkout:*)",
      "Bash(git rebase:*)",
      "Bash(git merge:*)",
      "Bash(git merge-base:*)",
      "Bash(git worktree:*)",
      "Bash(git stash:*)",
      "Bash(git restore:*)",
      "Bash(git config --get:*)",
      "Bash(git config user.email)",
      "Bash(git config user.name)",
      "Bash(gh pr view:*)",
      "Bash(gh pr diff:*)",
      "Bash(gh pr list:*)",
      "Bash(gh pr checks:*)",
      "Bash(gh pr create:*)",
      "Bash(gh pr ready:*)",
      "Bash(gh pr review:*)",
      "Bash(gh pr edit:*)",
      "Bash(gh pr comment:*)",
      "Bash(gh issue list:*)",
      "Bash(gh issue view:*)",
      "Bash(gh run list:*)",
      "Bash(gh run view:*)",
      "Bash(gh run watch:*)",
      "Bash(gh api:*)",
      "Bash(gh auth status:*)",
      "Bash(npm test:*)",
      "Bash(npm run:*)",
      "Bash(npm ci)",
      "Bash(npm install:*)",
      "Bash(npx:*)",
      "Bash(ls:*)",
      "Bash(mkdir:*)",
      "Bash(find:*)",
      "Bash(readlink:*)",
      "Bash(pwd)",
      "Bash(which:*)",
      "Bash(test:*)",
      "Bash(date:*)",
      "Bash(echo:*)",
      "Bash(cp:*)",
      "Bash(touch:*)",
      "Bash(sed:*)",
      "Bash(awk:*)",
      "Bash(head:*)",
      "Bash(tail:*)",
      "Bash(wc:*)"
    ],
    "ask": [
      "Bash(git push --force)",
      "Bash(git push -f)",
      "Bash(git push --force main:*)",
      "Bash(git push --force origin main:*)",
      "Bash(git reset --hard:*)",
      "Bash(git clean -f:*)",
      "Bash(git clean -fd:*)",
      "Bash(git branch -D:*)",
      "Bash(gh pr merge:*)",
      "Bash(gh pr close:*)",
      "Bash(gh release:*)",
      "Bash(rm -rf:*)",
      "Bash(rm -f:*)",
      "Bash(./deploy.sh:*)",
      "Bash(terraform apply:*)",
      "Bash(terraform destroy:*)"
    ]
  }
}
