# Claude Code worktrees (created by /proceed for parallel session isolation)
.claude/worktrees/
.worktrees/

# Per-user Claude Code overrides (team settings live in .claude/settings.json)
.claude/settings.local.json

# OS noise
.DS_Store

# Obsidian workspace (personal vault config — not shared)
.obsidian/

# ADLC pipeline state (ephemeral, per-worktree)
.adlc/specs/*/pipeline-state.json

# ADLC deployment logs
.adlc/logs/

# Gemini project-level rules (contains absolute path to toolkit — machine-specific, generated by /init)
.gemini/GEMINI.md
