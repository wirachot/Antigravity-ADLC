#!/usr/bin/env python3
"""ask-kimi — pack files into a corpus and ask Kimi K2.5 a question about them.

Files go before the question in the request so Moonshot's prefix cache can be
reused across multiple questions on the same corpus.
"""

import argparse
import os
import sys

sys.path.insert(0, os.path.dirname(os.path.abspath(__file__)))

import _common  # noqa: E402

_SYSTEM_PROMPT = (
    "You are a precise code analyst. Answer the question using only the provided "
    "files. Reply with a concise, structured summary (short sections / bullets) — "
    "do not dump file contents verbatim."
)


def _parse_args(argv=None):
    parser = argparse.ArgumentParser(
        prog="ask-kimi",
        description="Ask Kimi K2.5 a question about one or more files.",
    )
    parser.add_argument("--paths", nargs="+", required=True, help="files to read")
    parser.add_argument("--question", required=True, help="question to answer")
    parser.add_argument("--max-tokens", type=int, default=8192)
    parser.add_argument("--model", default=None)
    parser.add_argument(
        "--dry-run",
        action="store_true",
        help="print message structure and exit without calling the API",
    )
    parser.add_argument(
        "--no-warn",
        action="store_true",
        help="suppress the data-exfiltration notice",
    )
    return parser.parse_args(argv)


def main(argv=None):
    args = _parse_args(argv)

    # Skip unreadable paths with a warning instead of aborting the whole batch:
    # a single stale/missing path in a multi-file --paths set (e.g. one moved
    # knowledge doc among the top-15 a /spec or /analyze step delegates) must not
    # nullify the readable remainder. Only fail when NOTHING is readable — packing
    # an empty corpus would waste an API call. The consuming skills already
    # reconcile any expected-but-missing doc and read it directly, so a skipped
    # path is recovered downstream rather than silently lost (BUG-080).
    readable = []
    for p in args.paths:
        if os.path.isfile(p) and os.access(p, os.R_OK):
            readable.append(p)
        else:
            sys.stderr.write(f"ask-kimi: skipping unreadable path: {p}\n")
    if not readable:
        sys.exit("no readable files among --paths")

    messages = [
        {"role": "system", "content": _SYSTEM_PROMPT},
        {"role": "user", "content": f"<corpus>\n{_common.pack_corpus(readable)}\n</corpus>"},
        {"role": "user", "content": args.question},
    ]

    if args.dry_run:
        for m in messages:
            print(f"{m['role']}: {len(m['content'])} chars")
        return 0

    # Notice fires after the dry-run gate and after path validation, but BEFORE
    # get_client() so the user always sees the privacy notice for any real run —
    # even one that will fail later due to a missing key or auth error.
    if not args.no_warn and os.environ.get("KIMI_NO_WARN") != "1":
        _common.emit_exfil_notice()
    client = _common.get_client()
    model = args.model or _common.get_model()
    print(_common.complete(client, model, messages, args.max_tokens))
    return 0


if __name__ == "__main__":
    sys.exit(main())
